# Production environment (Coolify / Docker Compose)
# Copy values to Coolify env panel — NEVER commit real secrets

# ── Public URLs (required) ───────────────────────────────────────────────
APP_MARKETING_URL="https://onekart.info"
APP_BASE_URL="https://app.onekart.info"
APP_PAYMENT_URL="https://odeme.click"
API_PUBLIC_URL="https://api.onekart.info"
NEXT_PUBLIC_API_URL="https://api.onekart.info"
CORS_ORIGIN="https://app.onekart.info,https://onekart.info,https://odeme.click"

# ── PostgreSQL (required) ────────────────────────────────────────────────
POSTGRES_DB="onepara_card"
POSTGRES_USER="onepara"
POSTGRES_PASSWORD="change-me-db-password"
DATABASE_URL="postgresql://onepara:change-me-db-password@YOUR_COOLIFY_POSTGRES_HOST:5432/onepara_card"

# ── Redis (required) ─────────────────────────────────────────────────────
REDIS_URL="redis://YOUR_COOLIFY_REDIS_HOST:6379"

# ── App security (required) ──────────────────────────────────────────────
APP_SECRET="change-me-use-openssl-rand-hex-32"
APP_ENV="production"

# ── Cloudflare (DNS + SSL sync — api service) ───────────────────────────
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID="14cc9d8a8239fc9bc69265d82d9d8aa2"
CLOUDFLARE_ORIGIN_IP=""
CLOUDFLARE_ZONE_ID_ONEKART="583a4c1b8eca2293926b4926b462a215"
CLOUDFLARE_ZONE_ID_ODEME="7aba743cb513d4e7c9a8d6fc4e7863e7"
CLOUDFLARE_ZONE_DOMAIN_ONEKART="onekart.info"
CLOUDFLARE_ZONE_DOMAIN_ODEME="odeme.click"
CLOUDFLARE_AUTO_SYNC="1"

# fail2ban ignore file (api writes; bind-mount to host for fail2ban include)
FAIL2BAN_IGNORE_FILE="/app/data/fail2ban/onepos-ignore.conf"

# ── Coolify network (optional) ───────────────────────────────────────────
COOLIFY_NETWORK="coolify"

# ── BetConstruct wallet (optional) ───────────────────────────────────────
BC_SECRET=""

# ── Telegram (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ── PSP ───────────────────────────────────────────────────────────────────
PSP_DEFAULT_PROVIDER="stripe"
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="0"
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
SUMUP_API_KEY=""
SUMUP_MERCHANT_CODE=""

# ── Seeding (first deploy only) ──────────────────────────────────────────
# SEED_ALLOW="1"
# SEED_ADMIN_PASSWORD="use-a-strong-password"
