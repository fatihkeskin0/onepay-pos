# Production environment (Coolify / Docker Compose)
# Copy to Coolify env panel or .env.production — NEVER commit real values

# ── Public URLs (required — set explicitly; do not use SERVICE_URL_* in Coolify) ──
# Point two root domains at the web service (port 3105). Subdomains optional.
#
# APP_BASE_URL="https://onekart.info"
# APP_PAYMENT_URL="https://odeme.click"
# API_PUBLIC_URL="https://api.onekart.info"
# CORS_ORIGIN="https://onekart.info,https://odeme.click"

# ── PostgreSQL (required) ──────────────────────────────────────────────
POSTGRES_DB="onepara_card"
POSTGRES_USER="onepara"
POSTGRES_PASSWORD="change-me-db-password"
DATABASE_URL="postgresql://onepara:change-me-db-password@postgres:5432/onepara_card"

# ── Redis (required — rate limiting + cache) ───────────────────────────
REDIS_URL="redis://redis:6379"

# ── App security (required) ────────────────────────────────────────────
APP_SECRET="change-me-use-openssl-rand-hex-32"
APP_ENV="production"

# ── BetConstruct (optional) ────────────────────────────────────────────
BC_SECRET="change-me-bc-secret"
BC_API_URL="https://api.betconstruct.com"
BC_PARTNER_ID=""

# ── Telegram (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ── PSP — fallback only until Admin → POS Ayarları activates a provider ──
# Active PSP is chosen in the panel; this env is used only when no POS is enabled yet.
PSP_DEFAULT_PROVIDER="stripe"

# PayTR
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="0"

# Stripe (optional — only if PSP_DEFAULT_PROVIDER=stripe)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SumUp (optional — only if PSP_DEFAULT_PROVIDER=sumup)
SUMUP_API_KEY=""
SUMUP_MERCHANT_CODE=""

# ── Seeding (first deploy only) ────────────────────────────────────────
# Seeding is blocked in production unless SEED_ALLOW=1.
# SEED_ALLOW="1"
# SEED_ADMIN_PASSWORD="use-a-strong-password"
# SEED_AGENT_PASSWORD="use-a-strong-password"

# ── Docker build (set in Coolify web service build args) ───────────────
# Internal API URL for Next.js /backend proxy (do not change in compose)
# NEXT_PUBLIC_API_URL=http://api:4105
