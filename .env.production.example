# Production environment (Coolify / Docker Compose)
# Copy to Coolify env panel or .env.production — NEVER commit real values

# ── Public URLs (required) ─────────────────────────────────────────────
# Panel + payment pages (Coolify domain for web service)
APP_BASE_URL="https://pay.example.com"
APP_PAYMENT_URL="https://pay.example.com"

# Public API URL (PSP webhooks, external callbacks)
API_PUBLIC_URL="https://api.example.com"

# CORS — usually same as APP_BASE_URL
CORS_ORIGIN="https://pay.example.com"

# ── PostgreSQL (required) ──────────────────────────────────────────────
POSTGRES_DB="onepara_card"
POSTGRES_USER="onepara"
POSTGRES_PASSWORD="change-me-db-password"
DATABASE_URL="postgresql://onepara:change-me-db-password@postgres:5432/onepara_card"

# ── Redis (required — rate limiting + cache) ───────────────────────────
REDIS_URL="redis://redis:6379"

# ── App security (required) ────────────────────────────────────────────
APP_SECRET="change-me-use-openssl-rand-hex-32"
APP_ENV="production"

# ── BetConstruct (optional) ────────────────────────────────────────────
BC_SECRET="change-me-bc-secret"
BC_API_URL="https://api.betconstruct.com"
BC_PARTNER_ID=""

# ── Telegram (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ── PSP — only fill credentials for PSP_DEFAULT_PROVIDER ───────────────
# Other PSP blocks can stay empty.
PSP_DEFAULT_PROVIDER="paytr"

# PayTR
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="0"

# Stripe (optional — only if PSP_DEFAULT_PROVIDER=stripe)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SumUp (optional — only if PSP_DEFAULT_PROVIDER=sumup)
SUMUP_API_KEY=""
SUMUP_MERCHANT_CODE=""

# ── Docker build (set in Coolify web service build args) ───────────────
# Internal API URL for Next.js /backend proxy (do not change in compose)
# NEXT_PUBLIC_API_URL=http://api:4105
