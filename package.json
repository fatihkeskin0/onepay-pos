{
  "name": "onepara-credit-card",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev.mjs --clean",
    "dev:raw": "turbo dev",
    "clean:web": "node scripts/clean-next.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @onepara/db generate",
    "db:push": "pnpm --filter @onepara/db push",
    "db:seed": "pnpm --filter @onepara/db seed",
    "db:deploy": "pnpm --filter @onepara/db exec prisma db push"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
