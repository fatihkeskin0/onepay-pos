# Database (PostgreSQL)
DATABASE_URL="postgresql://onepara:onepara@localhost:5432/onepara_card"

# Redis (rate limiting + cache)
REDIS_URL="redis://localhost:6379"

# App
APP_SECRET="change-me-use-openssl-rand-hex-32"
APP_ENV="development"
WEB_PORT=3105
# Marketing (landing + /docs). Local split: localhost vs app.localhost
APP_MARKETING_URL="http://localhost:3105"
APP_BASE_URL="http://app.localhost:3105"
# Payment links (local: same as marketing; prod: https://odeme.click)
APP_PAYMENT_URL="http://localhost:3105"

# API
API_PORT=4105
API_PUBLIC_URL="http://localhost:4105"
API_HOST="0.0.0.0"

# Uploaded assets (site logos)
UPLOAD_DIR="data/uploads"
CORS_ORIGIN="http://localhost:3105,http://app.localhost:3105"
# Browser API origin (local: direct to API; prod: https://api.onekart.info)
NEXT_PUBLIC_API_URL="http://localhost:4105"

# BetConstruct seamless wallet callback signature (HMAC secret for /api/*)
# Leave default only in dev; set when integrating the wallet endpoints.
BC_SECRET="change-me-bc-secret"

# Telegram (optional)
TELEGRAM_BOT_TOKEN=""

# PSP — only fill credentials for your active provider (PSP_DEFAULT_PROVIDER)
# PayTR (primary)
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="1"

# Stripe (optional backup)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SumUp (optional backup)
SUMUP_API_KEY=""
SUMUP_MERCHANT_CODE=""

# Default PSP provider: paytr | stripe | sumup
PSP_DEFAULT_PROVIDER="stripe"
